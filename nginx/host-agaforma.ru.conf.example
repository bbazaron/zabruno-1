# На сервере:
#   sudo cp nginx/host-agaforma.ru.conf.example /etc/nginx/sites-available/agaforma.ru
#   sudo ln -sf /etc/nginx/sites-available/agaforma.ru /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Условие: контейнер nginx слушает 8081 (в корне репозитория в .env: NGINX_HTTP_PORT=8081).

server {
    listen 80;
    listen [::]:80;
    server_name agaforma.ru www.agaforma.ru;

    large_client_header_buffers 4 16k;
    client_header_buffer_size 16k;
    client_max_body_size 64m;

    location / {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
    }
}
