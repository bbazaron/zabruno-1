UID=1000
GID=1000

# Очереди: database — без пакета RabbitMQ. Для AMQP: composer require vladimir-yuldashev/laravel-queue-rabbitmq:^14.2, затем QUEUE_CONNECTION=rabbitmq
QUEUE_CONNECTION=rabbitmq

# RabbitMQ (сервис rabbitmq в docker-compose; хост rabbitmq, порт 5672 внутри сети)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=zabruno
RABBITMQ_PASSWORD=zabruno
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default
RABBITMQ_MAIL_QUEUE=mail