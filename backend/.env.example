APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database | sync | rabbitmq — для писем о заказе через RabbitMQ задайте rabbitmq и поднимите воркер: php artisan queue:work rabbitmq
QUEUE_CONNECTION=database

# RabbitMQ (vladimir-yuldashev/laravel-queue-rabbitmq)
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default
# Очередь только для почты заказов (OrderReceived); должна совпадать с очередью воркера или используйте ту же, что RABBITMQ_QUEUE
RABBITMQ_MAIL_QUEUE=mail
RABBITMQ_HEARTBEAT=60
# RABBITMQ_WORKER=horizon

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Debugmail — перехват исходящей почты в браузере (dev): https://debugmail.io
# В кабинете создайте проект и подставьте логин/пароль из SMTP.
# MAIL_MAILER=smtp
# MAIL_HOST=app.debugmail.io
# MAIL_PORT=9025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SCHEME не задавайте — для порта ≠ 465 Laravel выберет smtp (часто достаточно для Debugmail)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ЮKassa (оплата заказов). Без shop_id/secret_key заказ с суммой > 0 не создастся.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# URL сайта (Vue), куда вернётся клиент после оплаты — должен совпадать с зарегистрированным в личном кабинете ЮKassa
FRONTEND_URL=http://localhost:5173
# Вебхук ЮKassa: в кабинете укажите POST URL вида https://<ваш-домен>/yookassa/webhook (тот же хост, что и APP_URL для бэкенда)
